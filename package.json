{
  "name": "perso-dubbing",
  "version": "0.7.0",
  "description": "Perso AI video auto-dubbing agent skill — dubbing, lip-sync, audio separation, SRT subtitle extraction & translation (Claude Code / Codex / Cursor / Antigravity)",
  "license": "MIT",
  "type": "module",
  "bin": {
    "perso-dubbing": "scripts/install.mjs"
  },
  "files": [
    "skills",
    "scripts",
    ".claude-plugin",
    ".codex-plugin",
    ".cursor-plugin"
  ],
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://github.com/perso-ai/perso-dubbing-plugin#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/perso-ai/perso-dubbing-plugin.git"
  },
  "keywords": [
    "agent-skills",
    "skill",
    "plugin",
    "dubbing",
    "video-translation",
    "lip-sync",
    "srt",
    "subtitles",
    "speech-to-text",
    "perso-ai",
    "claude-code",
    "codex",
    "cursor",
    "antigravity"
  ],
  "scripts": {
    "doctor": "node skills/dubbing/scripts/check_deps.mjs",
    "key:check": "node skills/dubbing/scripts/resolve_key.mjs --check",
    "langs": "node skills/dubbing/scripts/languages.mjs",
    "input": "node skills/dubbing/scripts/prepare_input.mjs",
    "split": "node skills/dubbing/scripts/probe_split.mjs",
    "dub": "node skills/dubbing/scripts/dubbing.mjs",
    "srt": "node skills/srt/scripts/srt.mjs",
    "install:skill": "node scripts/install.mjs"
  }
}
